#!/bin/bash
# ============================================
# PRE-COMMIT HOOK: Validaciones de Seguridad y Calidad
# ============================================
# Este script se ejecuta ANTES de cada commit
# Si alguna validación falla, el commit se cancela
#
# Proyecto: egea-Main-control
# Fecha: 2026-01-17

set -e  # Salir si cualquier comando falla

# Colores para output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${BLUE}╔════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║     🔍 Pre-commit Validations Starting     ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════╝${NC}"

# ============================================
# 1. ESCANEO DE SECRETOS CON GITLEAKS
# ============================================
echo -e "\n${YELLOW}[1/5]${NC} 🔐 Escaneando secretos con Gitleaks..."

if command -v gitleaks &> /dev/null; then
    # Escanear solo archivos staged
    gitleaks protect --staged --verbose --config .gitleaks.toml 2>/dev/null || {
        echo -e "${RED}❌ BLOQUEADO: Se detectaron secretos en el código${NC}"
        echo -e "${RED}   Revisa los archivos marcados y elimina las credenciales.${NC}"
        echo -e "${YELLOW}   Consejo: Usa variables de entorno en Coolify, no en el código.${NC}"
        exit 1
    }
    echo -e "${GREEN}✅ No se detectaron secretos${NC}"
else
    echo -e "${YELLOW}⚠️  Gitleaks no instalado.${NC}"
    echo -e "${YELLOW}   Instala con: winget install Gitleaks.Gitleaks (Windows)${NC}"
    echo -e "${YELLOW}   O: brew install gitleaks (macOS)${NC}"
    echo -e "${YELLOW}   Continuando sin escaneo de secretos...${NC}"
fi

# ============================================
# 2. VERIFICAR ARCHIVOS PROHIBIDOS
# ============================================
echo -e "\n${YELLOW}[2/5]${NC} 📁 Verificando archivos prohibidos..."

STAGED_FILES=$(git diff --cached --name-only)

# Lista de patrones de archivos prohibidos
FORBIDDEN_PATTERNS=(
    "^\.env$"
    "^\.env\.local$"
    "^\.env\.development$"
    "^\.env\.production$"
    "\.pem$"
    "\.key$"
    "id_rsa"
    "id_ed25519"
    "credentials\.json"
    "service-account.*\.json"
)

for pattern in "${FORBIDDEN_PATTERNS[@]}"; do
    matches=$(echo "$STAGED_FILES" | grep -E "$pattern" || true)
    if [ -n "$matches" ]; then
        echo -e "${RED}❌ BLOQUEADO: Archivo prohibido detectado:${NC}"
        echo -e "${RED}   $matches${NC}"
        echo -e "${YELLOW}   Estos archivos contienen secretos y no deben estar en Git.${NC}"
        echo -e "${YELLOW}   Usa: git reset HEAD <archivo> para quitarlo del staging.${NC}"
        exit 1
    fi
done
echo -e "${GREEN}✅ No hay archivos prohibidos${NC}"

# ============================================
# 3. LINTING (ESLint)
# ============================================
echo -e "\n${YELLOW}[3/5]${NC} 🧹 Ejecutando Linter (ESLint)..."

if [ -f "package.json" ] && grep -q '"lint"' package.json; then
    npm run lint 2>&1 || {
        echo -e "${RED}❌ BLOQUEADO: El linting falló${NC}"
        echo -e "${YELLOW}   Corrige los errores de ESLint antes de hacer commit.${NC}"
        echo -e "${YELLOW}   Ejecuta: npm run lint -- --fix${NC}"
        exit 1
    }
    echo -e "${GREEN}✅ Linting pasó correctamente${NC}"
else
    echo -e "${YELLOW}⚠️  Script 'lint' no encontrado en package.json. Omitiendo...${NC}"
fi

# ============================================
# 4. VERIFICACIÓN DE TIPOS (TypeScript)
# ============================================
echo -e "\n${YELLOW}[4/5]${NC} 📝 Verificando tipos de TypeScript..."

if [ -f "tsconfig.json" ]; then
    if grep -q '"type-check"' package.json 2>/dev/null; then
        npm run type-check 2>&1 || {
            echo -e "${RED}❌ BLOQUEADO: Errores de TypeScript encontrados${NC}"
            echo -e "${YELLOW}   Revisa los errores de tipos antes de hacer commit.${NC}"
            exit 1
        }
    else
        # Ejecutar tsc directamente si no hay script type-check
        npx tsc --noEmit 2>&1 || {
            echo -e "${RED}❌ BLOQUEADO: Errores de TypeScript encontrados${NC}"
            echo -e "${YELLOW}   Revisa los errores de tipos antes de hacer commit.${NC}"
            exit 1
        }
    fi
    echo -e "${GREEN}✅ Tipos de TypeScript correctos${NC}"
else
    echo -e "${YELLOW}⚠️  tsconfig.json no encontrado. Omitiendo verificación de tipos...${NC}"
fi

# ============================================
# 5. BUILD DE PRUEBA (Opcional)
# ============================================
echo -e "\n${YELLOW}[5/5]${NC} 🏗️  Build de prueba..."

# ⚠️ NOTA: El build está comentado por defecto porque puede ser lento.
# Descomenta las siguientes líneas si quieres verificar el build antes de cada commit.
# Esto es especialmente útil para evitar despliegues fallidos en Coolify.

# BUILD_CHECK=${PRE_COMMIT_BUILD_CHECK:-false}
# if [ "$BUILD_CHECK" = "true" ]; then
#     if [ -f "package.json" ] && grep -q '"build"' package.json; then
#         echo -e "${YELLOW}   Ejecutando build (esto puede tomar un momento)...${NC}"
#         npm run build 2>&1 || {
#             echo -e "${RED}❌ BLOQUEADO: El build falló${NC}"
#             echo -e "${YELLOW}   El código no compila. Corrige los errores antes de hacer commit.${NC}"
#             exit 1
#         }
#         echo -e "${GREEN}✅ Build exitoso${NC}"
#     fi
# else
#     echo -e "${GREEN}⏭️  Build de prueba omitido${NC}"
#     echo -e "${YELLOW}   Para habilitar: PRE_COMMIT_BUILD_CHECK=true git commit ...${NC}"
# fi

echo -e "${GREEN}⏭️  Build de prueba omitido (habilitar en .husky/pre-commit si es necesario)${NC}"

# ============================================
# RESUMEN FINAL
# ============================================
echo -e "\n${GREEN}╔════════════════════════════════════════════╗${NC}"
echo -e "${GREEN}║      ✅ Todas las validaciones pasaron     ║${NC}"
echo -e "${GREEN}║         El commit puede proceder           ║${NC}"
echo -e "${GREEN}╚════════════════════════════════════════════╝${NC}"

exit 0
