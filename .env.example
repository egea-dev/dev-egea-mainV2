# Variables de Entorno - Ejemplo

# ⚠️ IMPORTANTE: Este es un archivo de ejemplo
# Copia este archivo como .env.local y completa con tus valores reales
# NO subas .env.local a GitHub (ya está en .gitignore)

# ===========================================
# MAIN DATABASE (Autenticación y Usuarios)
# ===========================================
VITE_SUPABASE_URL=https://tu-proyecto-main.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-main-aqui

# ===========================================
# PRODUCTIVITY DATABASE (Módulos de Negocio)
# ===========================================
VITE_SUPABASE_PRODUCTIVITY_URL=https://tu-proyecto-productivity.supabase.co
VITE_SUPABASE_PRODUCTIVITY_ANON_KEY=tu-anon-key-productivity-aqui

# ===========================================
# IMPRESORA ZEBRA (Opcional)
# ===========================================
# IP de tu Raspberry Pi en red local
# Ejemplo: http://192.168.1.100:3001
VITE_PRINTER_SERVER_URL=http://TU_IP_RASPBERRY:3001

# ===========================================
# NOTAS
# ===========================================
# 1. Obtén las URLs y keys desde Supabase Dashboard → Settings → API
# 2. Para Vercel, configura estas variables en: Project Settings → Environment Variables
# 3. La impresora solo funciona en red local (misma red que Raspberry Pi)
